# OpenRouter API key (for image extraction via AI)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Vision model to use via OpenRouter (default: google/gemini-2.0-flash-001)
# Cheap options: google/gemini-2.0-flash-001, deepseek/deepseek-chat-v3-0324 (no vision)
# For OCR: google/gemini-2.0-flash-001, anthropic/claude-3.5-sonnet, openai/gpt-4o-mini
VISION_MODEL=google/gemini-2.0-flash-001

# Notion integration (optional)
# Create at https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_xxxxx
NOTION_DATABASE_ID=your-database-id-here

# App URL (set to your Railway URL after deploy)
APP_URL=https://your-app.up.railway.app

# Port (Railway sets this automatically)
PORT=3000
